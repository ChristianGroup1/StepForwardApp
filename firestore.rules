rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() 
        && userExists()
        && userDoc().data.isAdmin == true;
    }

    function isApproved() {
      return signedIn() 
        && userExists()
        && userDoc().data.isApproved == true;
    }

    function teamDoc(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId));
    }

    function isTeamMember(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teams/$(teamId))
        && teamDoc(teamId).data.members is list
        && request.auth.uid in teamDoc(teamId).data.members;
    }

    function canAccessTeam(teamId) {
      // Check membership first — most users are members, not admins.
      return isTeamMember(teamId) || isAdmin();
    }

    function canManageTeam(teamId) {
      let team = teamDoc(teamId);
      return signedIn()
        && exists(/databases/$(database)/documents/teams/$(teamId))
        && (request.auth.uid == team.data.ownerId || isAdmin());
    }

    function isJoiningSelf() {
      return signedIn()
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt'])
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.size() == resource.data.members.size() + 1;
    }

    function isLeavingSelf() {
      return signedIn()
        && request.auth.uid in resource.data.members
        && !(request.auth.uid in request.resource.data.members)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt'])
        && resource.data.members.hasAll(request.resource.data.members)
        && resource.data.members.size() == request.resource.data.members.size() + 1;
    }

    function isRefreshingExistingMembership() {
      return signedIn()
        && request.auth.uid in resource.data.members
        && request.auth.uid in request.resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt'])
        && request.resource.data.members.hasAll(resource.data.members)
        && resource.data.members.hasAll(request.resource.data.members);
    }

    function canRemoveTeamMember(teamId) {
      return canManageTeam(teamId)
        && resource.data.members is list
        && request.resource.data.members is list
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt'])
        && resource.data.members.hasAll(request.resource.data.members)
        && request.resource.data.members.size() == resource.data.members.size() - 1
        && request.resource.data.ownerId == resource.data.ownerId
        && resource.data.ownerId in request.resource.data.members;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isAdmin() || (signedIn() && request.auth.uid == userId);

      match /serviceHistory/{historyId} {
        allow read, write: if isAdmin() || (signedIn() && request.auth.uid == userId);
      }
    }

    match /brothers/{docId} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /games/{docId} {
      allow read: if signedIn();

      allow create, delete: if isAdmin();

      allow update: if isAdmin()
        || (
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['ratingSum', 'ratingCount', 'ratingAverage'])
        );

      match /ratings/{ratingId} {
        allow read: if signedIn();
        allow write: if signedIn() && request.auth.uid == ratingId;
      }
    }

    match /books/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /teamGames/{gameId} {
      allow read: if signedIn()
        && resource.data.teamId is string
        && canAccessTeam(resource.data.teamId);

      allow create: if signedIn()
        && request.resource.data.teamId is string
        && canManageTeam(request.resource.data.teamId);

      allow update, delete: if signedIn()
        && resource.data.teamId is string
        && canManageTeam(resource.data.teamId);
    }

    match /teams/{teamId} {
      // Any signed-in user can read a single team doc — required so a user
      // can fetch the team by invite code before they are a member.
      allow get: if signedIn();

      // Matches the client query: where('members', arrayContains: uid)
      allow list: if isAdmin()
        || (signedIn()
          && resource.data.members is list
          && request.auth.uid in resource.data.members);

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      allow update: if isAdmin()
        || isJoiningSelf()
        || isRefreshingExistingMembership()
        || isLeavingSelf()
        || canRemoveTeamMember(teamId);

      allow delete: if isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid);

      match /shared/{docId} {
        allow read, write: if canAccessTeam(teamId);
      }

      match /serviceHistory/{historyId} {
        allow read, write: if canAccessTeam(teamId);
      }
    }
  }
}
